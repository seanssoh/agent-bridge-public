logs/
state/
shared/
# But the tracked runtime-template `shared/` overlay is source, not live runtime
# state (it ships the wiki seeds + the #1762 picker catalog). The broad `shared/`
# ignore above is for the LIVE runtime ~/.agent-bridge/shared.
!runtime-templates/shared/
!runtime-templates/shared/**
migration/
__pycache__/
*.pyc
.DS_Store
.env*
*.key
*.pem
*.p12
*.secret
*.sqlite
*.db
*.bak*
credentials.json
service-account*.json
node_modules/
backups/
.oss-preflight-patterns
agent-roster.local.sh
# A2A cross-bridge handoff peer config (secrets + tailnet addresses).
# Tracked example: handoff.local.example.json.
handoff.local.json
HEARTBEAT.md
agents/*/.claude/
# Shared agent settings (symlink target) is tracked
!agents/.claude/
!agents/.claude/settings.json
!agents/_template/session-type-files/
!agents/_template/session-type-files/**
!agents/_template/.claude/
!agents/_template/.claude/**
!agents/_template/.claude/settings.json
# But never ship a per-install local settings file
agents/_template/.claude/settings.local.json
agents/.claude/settings.local.json
agents/.claude/settings.effective.json

# Local developer harness (worker agents + orchestrator skills for repo
# workflow). Tracked plugin skills under .claude/skills/<name>/ stay
# committed via explicit git add; everything else under these paths is
# machine-local.
.claude/agents/
.claude/skills/upstream-issue-fix/
