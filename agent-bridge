prompt_spawn_mode() {
  local can_create_worktree="$1"
  local project_root="$2"
  shift 2
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate
  local state=""

  echo "[info] 현재 프로젝트에 정적 ${ENGINE} 역할이 있습니다: $project_root" >&2
  for candidate in "${candidates[@]}"; do
    if bridge_agent_is_active "$candidate"; then
      state="active (연결됨)"
    else
      state="stopped"
    fi
    printf '  %d. %s | session=%s | %s | workdir=%s\n' \
      "$index" \
      "$candidate" \
      "$(bridge_agent_session "$candidate")" \
      "$state" \
      "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done
  echo >&2
  echo "1) 기존 정적 역할 연결/깨우기 (권장)" >&2
  if [[ "$can_create_worktree" == "1" ]]; then
    echo "2) 새 isolated worktree worker 만들기 (고급)" >&2
    echo "3) 현재 checkout에서 새 dynamic worker 만들기" >&2
  else
    echo "2) 현재 checkout에서 새 dynamic worker 만들기" >&2
  fi

  while true; do
    printf '선택: ' >&2
    read -r choice
    case "$choice" in
      1)
        printf 'wake'
        return 0
        ;;
      2)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'new'
        else
          printf 'shared'
        fi
        return 0
        ;;
      3)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'shared'
          return 0
        fi
        ;;
    esac
    echo "올바른 번호를 입력하세요." >&2
  done
}

prompt_static_candidate() {
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate
  local state=""

  if [[ ${#candidates[@]} -eq 1 ]]; then
    printf '%s' "${candidates[0]}"
    return 0
  fi

  echo "[info] 연결/깨울 정적 역할을 선택하세요." >&2
  for candidate in "${candidates[@]}"; do
    if bridge_agent_is_active "$candidate"; then
      state="active (연결됨)"
    else
      state="stopped"
    fi
    printf '  %d. %s | session=%s | %s | workdir=%s\n' \
      "$index" \
      "$candidate" \
      "$(bridge_agent_session "$candidate")" \
      "$state" \
      "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done

  while true; do
    printf '역할 번호: ' >&2
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidates[@]} )); then
      printf '%s' "${candidates[$((choice - 1))]}"
      return 0
    fi
    echo "올바른 번호를 입력하세요." >&2
  done
}

start_static_agent() {
  local agent="$1"
  local start_args=()

  "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

  if [[ $REPLACE_MODE -eq 1 ]]; then
    start_args+=(--replace)
  fi
  if [[ $CONTINUE_EXPLICIT -eq 1 ]]; then
    if [[ $CONTINUE_MODE -eq 1 ]]; then
      start_args+=(--continue)
    else
      start_args+=(--no-continue)
    fi
  fi
  if [[ $ATTACH_MODE -eq 1 ]]; then
    start_args+=(--attach)
  fi
  if [[ $INSTALL_PROJECT_SKILL -eq 0 ]]; then
    start_args+=(--skip-project-skill)
  fi

  exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$agent" "${start_args[@]}"
}

# Issue #283 Track D: bare invocation prints help instead of falling through
# to the legacy ad-hoc spawn parser, which dies with the misleading
# "--codex 또는 --claude 중 하나를 지정하세요" error. The legacy spawn path is
# rare; the common path is queue/inbox dispatching, which is what the help
# summary highlights.
if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 ]]; then
  case "$1" in
    admin)
      shift
      ADMIN_AGENT="$(bridge_require_admin_agent)"
      ADMIN_ENGINE="$(bridge_agent_engine "$ADMIN_AGENT")"
      ADMIN_WORKDIR="$(bridge_agent_workdir "$ADMIN_AGENT")"
      ADMIN_SAFE_MODE=0
      ADMIN_REPLACE_MODE=0
      ADMIN_ATTACH_MODE=1
      ADMIN_FAST_REUSE_ELIGIBLE=1
      ADMIN_SESSION=""
      ADMIN_ARGS=()

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --safe-mode)
            ADMIN_SAFE_MODE=1
            shift
            ;;
          --replace)
            ADMIN_REPLACE_MODE=1
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --no-attach)
            ADMIN_ATTACH_MODE=0
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --continue|--no-continue|--no-project-skill)
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --name|--workdir|--codex|--claude)
            bridge_die "'$CLI_NAME admin'은(는) 관리자 역할의 engine/workdir/name을 고정 사용합니다."
            ;;
          *)
            ADMIN_FAST_REUSE_ELIGIBLE=0
            ADMIN_ARGS+=("$@")
            break
            ;;
        esac
      done
      if ((${#ADMIN_ARGS[@]} > 0)); then
        set -- "${ADMIN_ARGS[@]}"
      else
        set --
      fi

      if [[ $ADMIN_SAFE_MODE -eq 1 ]]; then
        exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-agent.sh" safe-mode "$ADMIN_AGENT" "$@"
      fi

      # Common path: `agb admin` is often just "return to the running admin".
      # Avoid the recursive static-start path, daemon ensure, and another full
      # roster load when the admin tmux session already exists.
      ADMIN_SESSION="$(bridge_agent_session "$ADMIN_AGENT")"
      if [[ $ADMIN_FAST_REUSE_ELIGIBLE -eq 1 && $ADMIN_REPLACE_MODE -eq 0 \
          && -n "$ADMIN_SESSION" ]] \
          && bridge_tmux_session_exists "$ADMIN_SESSION"; then
        echo "[info] 세션 '$ADMIN_SESSION'이 이미 실행 중입니다."
        if [[ $ADMIN_ATTACH_MODE -eq 1 ]]; then
          bridge_attach_tmux_session "$ADMIN_SESSION"
        fi
        exit 0
      fi

      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/agent-bridge" "--$ADMIN_ENGINE" --name "$ADMIN_AGENT" --workdir "$ADMIN_WORKDIR" --loop "$@"
      ;;
    bootstrap)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-bootstrap.sh" "$@"
      ;;
    init)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-init.sh" "$@"
      ;;
    version)
      shift
      VERSION_JSON=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json)
            VERSION_JSON=1
            shift
            ;;
          -h|--help)
            echo "Usage: $CLI_NAME version [--json]"
            exit 0
            ;;
          *)
            bridge_die "지원하지 않는 version 옵션입니다: $1"
            ;;
        esac
      done

      CURRENT_VERSION="$(bridge_version)"
      SOURCE_HEAD="$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null || printf '')"
      SOURCE_SHORT="$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || printf '-')"
      SOURCE_REF="$(bridge_source_ref)"
      UPGRADE_STATE_FILE="$BRIDGE_HOME/state/upgrade/last-upgrade.json"

      if [[ $VERSION_JSON -eq 1 ]]; then
        bridge_require_python
        python3 - "$CURRENT_VERSION" "$SCRIPT_DIR" "$SOURCE_REF" "$SOURCE_HEAD" "$UPGRADE_STATE_FILE" <<'PY'
import json
import sys
from pathlib import Path

version, source_root, source_ref, source_head, state_file = sys.argv[1:]
state_path = Path(state_file)
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except (FileNotFoundError, json.JSONDecodeError):
    state = {}

state_summary = {
    key: state.get(key, "")
    for key in ("version", "source_ref", "source_head", "source_root", "channel", "updated_at")
    if key in state
}
payload = {
    "version": version,
    "source_root": source_root,
    "source_ref": source_ref,
    "source_head": source_head,
    "installed": state_summary,
}
print(json.dumps(payload, ensure_ascii=False, indent=2))
PY
        exit 0
      fi

      echo "Agent Bridge $CURRENT_VERSION"
      echo "source_root: $SCRIPT_DIR"
      echo "source_ref: $SOURCE_REF"
      echo "source_head: $SOURCE_SHORT"
      if [[ -f "$UPGRADE_STATE_FILE" ]]; then
        bridge_require_python
        python3 - "$UPGRADE_STATE_FILE" <<'PY'
import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except (FileNotFoundError, json.JSONDecodeError):
    raise SystemExit(0)

if payload.get("version"):
    print(f"installed_version: {payload.get('version')}")
if payload.get("source_ref"):
    print(f"installed_ref: {payload.get('source_ref')}")
if payload.get("source_head"):
    print(f"installed_head: {str(payload.get('source_head'))[:12]}")
PY
      fi
      exit 0
      ;;
    upgrade)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-upgrade.sh" "$@"
      ;;
    daemon)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" "$@"
      ;;
    escalate)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-escalate.sh" "$@"
      ;;
    upstream)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-upstream.sh" "$@"
      ;;
    review)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-review.sh" "$@"
      ;;
    user)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-user.sh" "$@"
      ;;
    guard)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-guard.sh" "$@"
      ;;
    diagnose)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-diagnose.sh" "$@"
      ;;
    doctor)
      shift
      bridge_require_python
      exec python3 "$SCRIPT_DIR/bridge-doctor.py" "$@"
      ;;
    knowledge)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-knowledge.sh" "$@"
      ;;
    skills)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-skills-cli.sh" "$@"
      ;;
    config)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-config.sh" "$@"
      ;;
    bundle)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-bundle.sh" "$@"
      ;;
    intake)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-intake.sh" "$@"
      ;;
    wave)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-wave.sh" "$@"
      ;;
    list)
      if [[ $# -ne 1 ]]; then
      bridge_die "Usage: $CLI_NAME list"
      fi
      bridge_list_active_agents_numbered
      exit 0
      ;;
    status)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-status.sh" "$@"
      ;;
    kill)
      if [[ $# -ne 2 ]]; then
        bridge_die "Usage: $CLI_NAME kill <number|name|all>"
      fi

      if [[ "$2" == "all" ]]; then
        bridge_kill_all_active_agents
      elif [[ "$2" =~ ^[0-9]+$ ]]; then
        bridge_kill_active_agent_by_index "$2"
      else
        if bridge_agent_is_active "$2"; then
          bridge_manual_stop_agent_session "$2"
          bridge_refresh_runtime_state
        else
          bridge_die "에이전트 '$2'가 활성 상태가 아닙니다."
        fi
      fi
      exit 0
      ;;
    attach)
      if [[ $# -gt 2 ]]; then
        bridge_die "Usage: $CLI_NAME attach [number|name]"
      fi
      if [[ $# -eq 1 ]]; then
        if ! is_tty; then
          bridge_die "Usage: $CLI_NAME attach <number|name>"
        fi
        echo "Active sessions:" >&2
        bridge_list_active_agents_numbered >&2
        printf 'Attach to: ' >&2
        read -r attach_choice
        [[ -n "$attach_choice" ]] || bridge_die "attach target is required"
        set -- "$1" "$attach_choice"
      fi
      if [[ "$2" =~ ^[0-9]+$ ]]; then
        agent="$(bridge_active_agent_id_by_index "$2")" || bridge_die "활성 에이전트 번호가 올바르지 않습니다: $2"
      else
        agent="$2"
      fi
      session="$(bridge_agent_session "$agent")"
      if [[ -z "$session" ]] || ! bridge_tmux_session_exists "$session"; then
        bridge_die "에이전트 '$agent' 세션이 존재하지 않습니다."
      fi
      bridge_attach_tmux_session "$session"
      ;;
    urgent)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-send.sh" --urgent "$@"
      ;;
    task)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
    profile)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-profile.sh" "$@"
      ;;
    setup)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-setup.sh" "$@"
      ;;
    agent)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-agent.sh" "$@"
      ;;
    cron)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-cron.sh" "$@"
      ;;
    memory)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-memory.sh" "$@"
      ;;
    audit)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-audit.sh" "$@"
      ;;
    usage)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-usage.sh" "$@"
      ;;
    watchdog)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-watchdog.sh" "$@"
      ;;
    discord)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-discord-relay.sh" "$@"
      ;;
    migrate)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-migrate.sh" "$@"
      ;;
    wiki)
      shift
      bridge_require_python
      exec python3 "$SCRIPT_DIR/bridge-wiki.py" "$@"
      ;;
    isolate)
      shift
      bridge_migration_isolate_cli "$@"
      exit 0
      ;;
    unisolate)
      shift
      bridge_migration_unisolate_cli "$@"
      exit 0
      ;;
    worktree)
      shift
      case "${1:-}" in
        list|"")
          if [[ $# -gt 1 ]]; then
            bridge_die "Usage: $CLI_NAME worktree list"
          fi
          bridge_list_worktrees
          exit 0
          ;;
        *)
          bridge_die "지원하지 않는 worktree 명령입니다: $1"
          ;;
      esac
      ;;
    inbox|show|claim|done|cancel|update|handoff|summary|create)
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
  esac

  # Issue #163: if the first arg survived the top-level case and does not
  # start with `-` it is overwhelmingly a mistyped subcommand (e.g.
  # `agent-bridge health`, `agent-bridge diag`). Letting it fall through
  # into the spawn-flag parser surfaces the misleading "알 수 없는 옵션"
  # error, which previously redirected agents into option-guessing or the
  # sqlite3 fallback path. Reject with an intent-recovery suggestion
  # before the spawn parser sees it.
  if [[ -n "${1:-}" && "${1:0:1}" != "-" ]]; then
    _top_valid="admin bootstrap init version upgrade escalate upstream review user guard diagnose doctor knowledge config bundle intake list status kill attach urgent task profile setup agent cron memory audit usage watchdog discord migrate wiki isolate unisolate worktree inbox show claim done cancel update handoff summary create"
    _hint="$(bridge_suggest_subcommand "$1" "$_top_valid")"
    [[ -n "$_hint" ]] && bridge_warn "$_hint"
    bridge_die "지원하지 않는 명령입니다: $1"
  fi
fi

ENGINE=""
NAME=""
WORKDIR="$(pwd)"
WORKDIR_EXPLICIT=0
LOOP_MODE=0
CONTINUE_MODE=1
CONTINUE_EXPLICIT=0
ATTACH_MODE=1
REPLACE_MODE=0
INSTALL_PROJECT_SKILL=1
SPAWN_PREFERENCE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --codex)
      ENGINE="codex"
      shift
      ;;
    --claude)
      ENGINE="claude"
      shift
      ;;
    --name)
      [[ $# -lt 2 ]] && bridge_die "--name 뒤에 에이전트 이름을 지정하세요."
      NAME="$2"
      shift 2
      ;;
    --loop)
      LOOP_MODE=1
      shift
      ;;
    --no-continue)
      CONTINUE_MODE=0
      CONTINUE_EXPLICIT=1
      shift
      ;;
    --continue)
      CONTINUE_MODE=1
      CONTINUE_EXPLICIT=1
      shift
      ;;
    --workdir)
      [[ $# -lt 2 ]] && bridge_die "--workdir 뒤에 경로를 지정하세요."
      WORKDIR="$2"
      WORKDIR_EXPLICIT=1
      shift 2
      ;;
    --replace)
      REPLACE_MODE=1
      shift
      ;;
    --no-attach)
      ATTACH_MODE=0
      shift
      ;;
    --no-project-skill)
      INSTALL_PROJECT_SKILL=0
      shift
      ;;
    --prefer)
      [[ $# -lt 2 ]] && bridge_die "--prefer 뒤에 wake|new|shared 중 하나를 지정하세요."
      SPAWN_PREFERENCE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      bridge_die "알 수 없는 옵션: $1"
      ;;
  esac
done

[[ -z "$ENGINE" ]] && bridge_die "--codex 또는 --claude 중 하나를 지정하세요."
[[ -z "$NAME" ]] && bridge_die "--name은 필수입니다."

if ! bridge_validate_agent_name "$NAME"; then
  # Issue #526: same leading-dash / reserved-name rejection as `agent
  # create`. Helps users who accidentally typed `--name --help`.
  case "$NAME" in
    -*)
      bridge_die "이름이 CLI 플래그처럼 보입니다: '$NAME'. 도움말은 '$CLI_NAME --help' 를 실행하세요."
      ;;
    *)
      bridge_die "이름은 영문/숫자/점/밑줄/하이픈만 허용하고 영문/숫자로 시작해야 하며 'help'/'version' 은 예약어입니다: $NAME"
      ;;
  esac
fi

case "$SPAWN_PREFERENCE" in
  ""|wake|new|shared)
    ;;
  *)
    bridge_die "--prefer 는 wake|new|shared 중 하나여야 합니다."
    ;;
esac

WORKDIR="$(cd "$WORKDIR" && pwd -P)"

if ! bridge_agent_exists "$NAME"; then
  if RESOLVED_AGENT="$(bridge_agent_id_for_session "$NAME")"; then
    echo "[info] 세션 '$NAME'은(는) 역할 '$RESOLVED_AGENT'에 연결됩니다."
    NAME="$RESOLVED_AGENT"
  fi
fi

if bridge_agent_exists "$NAME" && [[ "$(bridge_agent_source "$NAME")" == "static" ]]; then
  STATIC_ENGINE="$(bridge_agent_engine "$NAME")"
  STATIC_WORKDIR="$(bridge_agent_workdir "$NAME")"
  if [[ -d "$STATIC_WORKDIR" ]]; then
    STATIC_WORKDIR="$(cd "$STATIC_WORKDIR" && pwd -P)"
  fi

  if [[ "$STATIC_ENGINE" != "$ENGINE" ]]; then
    bridge_die "'$NAME'은(는) ${STATIC_ENGINE} 정적 역할입니다. 요청 엔진(${ENGINE})과 다릅니다."
  fi
  if [[ $WORKDIR_EXPLICIT -eq 1 && "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    bridge_die "'$NAME' 정적 역할은 workdir이 고정되어 있습니다: $STATIC_WORKDIR"
  fi
  if [[ "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    echo "[info] '$NAME' 정적 역할의 고정 workdir을 사용합니다: $STATIC_WORKDIR"
    WORKDIR="$STATIC_WORKDIR"
  fi

  start_static_agent "$NAME"
fi

PROJECT_ROOT="$(bridge_project_root_for_path "$WORKDIR")"
IS_GIT_PROJECT=0
if git -C "$WORKDIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  IS_GIT_PROJECT=1
fi

mapfile -t STATIC_CANDIDATES < <(bridge_static_agents_for_project_engine "$PROJECT_ROOT" "$ENGINE")
if [[ ${#STATIC_CANDIDATES[@]} -gt 0 ]]; then
  if [[ -z "$SPAWN_PREFERENCE" ]] && is_tty; then
    SPAWN_PREFERENCE="$(prompt_spawn_mode "$IS_GIT_PROJECT" "$PROJECT_ROOT" "${STATIC_CANDIDATES[@]}")"
    echo
  elif [[ -z "$SPAWN_PREFERENCE" ]]; then
    if [[ ${#STATIC_CANDIDATES[@]} -eq 1 ]]; then
      SPAWN_PREFERENCE="wake"
    else
      SPAWN_PREFERENCE="shared"
    fi
  fi

  case "$SPAWN_PREFERENCE" in
    wake)
      if is_tty; then
        WAKE_AGENT="$(prompt_static_candidate "${STATIC_CANDIDATES[@]}")"
      elif [[ ${#STATIC_CANDIDATES[@]} -eq 1 ]]; then
        WAKE_AGENT="${STATIC_CANDIDATES[0]}"
      else
        bridge_die "깨울 정적 역할이 여러 개입니다. TTY에서 선택하거나 --name 으로 정적 역할을 직접 지정하세요."
      fi
      echo "[info] 새 dynamic worker '$NAME' 대신 정적 역할 '$WAKE_AGENT'를 깨웁니다."
      start_static_agent "$WAKE_AGENT"
      ;;
    new)
      if [[ "$IS_GIT_PROJECT" != "1" ]]; then
        bridge_die "현재 경로는 git 프로젝트가 아니어서 isolated worktree를 만들 수 없습니다: $WORKDIR"
      fi
      WORKDIR="$(bridge_prepare_isolated_worktree "$ENGINE" "$NAME" "$WORKDIR")"
      REPLACE_MODE=1
      echo "[info] isolated worktree를 사용합니다: $WORKDIR"
      ;;
    shared)
      :
      ;;
  esac
fi

ACTIVE_FILE="$(bridge_dynamic_agent_file_for "$NAME")"
HISTORY_FILE="$(bridge_history_file_for "$ENGINE" "$NAME" "$WORKDIR")"
SESSION_ID=""

if [[ -f "$ACTIVE_FILE" ]]; then
  bridge_load_roster
  if bridge_agent_is_active "$NAME" && [[ $REPLACE_MODE -eq 0 ]]; then
    EXISTING_ENGINE="$(bridge_agent_engine "$NAME")"
    EXISTING_WORKDIR="$(bridge_agent_workdir "$NAME")"
    EXISTING_LOOP="$(bridge_agent_loop "$NAME")"
    EXISTING_CONTINUE="$(bridge_agent_continue "$NAME")"

    if [[ "$EXISTING_ENGINE" != "$ENGINE" || "$EXISTING_WORKDIR" != "$WORKDIR" || "$EXISTING_LOOP" != "$LOOP_MODE" || "$EXISTING_CONTINUE" != "$CONTINUE_MODE" ]]; then
      bridge_die "'$NAME' 세션이 이미 실행 중이지만 요청한 설정과 다릅니다. existing: engine=$EXISTING_ENGINE workdir=$EXISTING_WORKDIR loop=$EXISTING_LOOP continue=$EXISTING_CONTINUE | requested: engine=$ENGINE workdir=$WORKDIR loop=$LOOP_MODE continue=$CONTINUE_MODE | '$CLI_NAME kill <number>' 또는 '--replace'를 사용하세요."
    fi

    echo "[info] '$NAME' 세션이 이미 실행 중입니다. 기존 세션에 연결합니다."
    if [[ $ATTACH_MODE -eq 1 ]]; then
      bridge_attach_tmux_session "$(bridge_agent_session "$NAME")"
    fi
    exit 0
  fi
fi

if [[ $CONTINUE_MODE -eq 1 && -f "$HISTORY_FILE" ]]; then
  AGENT_SESSION_ID=""
  # shellcheck source=/dev/null
  source "$HISTORY_FILE"
  # Gate the stored id through the freshness resolver. rc=0 keeps it,
  # rc=2 swaps in a fresher in-window transcript for the same workdir,
  # anything else means start fresh (no --resume). This is the dynamic
  # ad-hoc analogue of the hydration sites in lib/bridge-state.sh.
  _RESUME_RC=0
  SESSION_ID="$(bridge_resolve_resume_session_id "$ENGINE" "$NAME" "$WORKDIR" "${AGENT_SESSION_ID:-}" 2>/dev/null)" || _RESUME_RC=$?
  case "$_RESUME_RC" in
    0|2) ;;
    *)   SESSION_ID="" ;;
  esac
  unset _RESUME_RC
fi

bridge_add_agent_id_if_missing "$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_DESC["$NAME"]="Ad hoc ${ENGINE} agent (${WORKDIR})"
# shellcheck disable=SC2034
BRIDGE_AGENT_ENGINE["$NAME"]="$ENGINE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION["$NAME"]="$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_WORKDIR["$NAME"]="$WORKDIR"
# shellcheck disable=SC2034
BRIDGE_AGENT_SOURCE["$NAME"]="dynamic"
# shellcheck disable=SC2034
BRIDGE_AGENT_META_FILE["$NAME"]="$ACTIVE_FILE"
# shellcheck disable=SC2034
BRIDGE_AGENT_LOOP["$NAME"]="$LOOP_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_CONTINUE["$NAME"]="$CONTINUE_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION_ID["$NAME"]="$SESSION_ID"
# shellcheck disable=SC2034
BRIDGE_AGENT_HISTORY_KEY["$NAME"]="$(bridge_history_key_for "$ENGINE" "$NAME" "$WORKDIR")"
# shellcheck disable=SC2034
BRIDGE_AGENT_CREATED_AT["$NAME"]="$(date +%s)"
# shellcheck disable=SC2034
BRIDGE_AGENT_UPDATED_AT["$NAME"]="$(bridge_now_iso)"
bridge_write_dynamic_agent_file "$NAME" "$ACTIVE_FILE"

"$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

START_ARGS=()
if [[ $REPLACE_MODE -eq 1 ]]; then
  START_ARGS+=(--replace)
fi
if [[ $ATTACH_MODE -eq 1 ]]; then
  START_ARGS+=(--attach)
fi
if [[ $INSTALL_PROJECT_SKILL -eq 0 ]]; then
  START_ARGS+=(--skip-project-skill)
fi

exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$NAME" "${START_ARGS[@]}"
