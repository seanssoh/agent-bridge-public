#!/usr/bin/env bash
# agent-bridge — primary Agent Bridge CLI

set -euo pipefail

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# Issue #665 (r2): the public CLI wrapper sources bridge-lib.sh BEFORE it
# dispatches to bridge-init.sh / bridge-bootstrap.sh, so the resolver
# fires here in the wrapper process — armed with the wrapper's PID and
# argv ("agent-bridge"). Without arming the fresh-install bypass before
# the source below, a markerless fresh home dies inside the resolver
# (line ~369 of lib/bridge-layout-resolver.sh) before the wrapper ever
# reaches the dispatch table. Mirror what bridge-init.sh / bridge-
# bootstrap.sh do for direct invocations: peek at $1 and arm the bypass
# only for the fresh-install-creating subcommands. The handshake in
# lib/bridge-layout-resolver.sh accepts "agent-bridge" alongside
# "bridge-init.sh" / "bridge-bootstrap.sh" for exactly this case.
case "${1:-}" in
  init|bootstrap)
    if [[ -z "${BRIDGE_LAYOUT_RESOLVER_BYPASS:-}" ]]; then
      _BRIDGE_AGENT_BRIDGE_BYPASS_NONCE="$(date -u '+%Y%m%dT%H%M%SZ')-$$-${RANDOM}${RANDOM}"
      export BRIDGE_LAYOUT_RESOLVER_BYPASS="fresh-install:${_BRIDGE_AGENT_BRIDGE_BYPASS_NONCE}"
      export BRIDGE_LAYOUT_RESOLVER_BYPASS_OWNER_PID=$$
      trap 'unset BRIDGE_LAYOUT_RESOLVER_BYPASS BRIDGE_LAYOUT_RESOLVER_BYPASS_OWNER_PID' EXIT
    fi
    ;;
  upgrade|migrate)
    # v0.8.6 hotfix: arm the upgrade-migrate resolver bypass before
    # `bridge-lib.sh` is sourced below — but ONLY when the live install
    # is markerless (v0.7.x or earlier, no `state/layout-marker.sh`).
    # Without the bypass, an operator running `agent-bridge upgrade
    # --apply` or `agent-bridge migrate isolation-v2 ...` from a v0.8.5
    # source checkout against a markerless v0.7.x install hits the
    # v0.8.0 fail-fast at `lib/bridge-layout-resolver.sh:333-345`
    # before the wrapper's own `case` block can dispatch to
    # `bridge-upgrade.sh` / `bridge-migrate.sh` (which arm the bypass
    # themselves but only AFTER they're exec'd, by which time the
    # wrapper has already died).
    #
    # Markered v0.8.x installs MUST NOT take the bypass path — the
    # resolver's bypass branch (line 297-300) returns
    # `upgrade-migrate-deferred` before consulting the marker, which
    # would leave BRIDGE_LAYOUT/BRIDGE_DATA_ROOT unset for the
    # wrapper's own `bridge_load_roster` call (line 54) and silently
    # operate against legacy paths. Gate the bypass on marker absence
    # so already-migrated installs continue to take the normal marker
    # branch (codex review on PR #704 r3 caught this).
    #
    # Mirrors the fresh-install bypass arming for `init|bootstrap`
    # above. The handshake in `lib/bridge-layout-resolver.sh` accepts
    # `agent-bridge` alongside `bridge-upgrade.sh` /
    # `bridge-migrate.sh` as owner so a leaked env crossing into
    # another tree still fails the descendant check.
    _BRIDGE_AGENT_BRIDGE_HOME="${BRIDGE_HOME:-$HOME/.agent-bridge}"
    _BRIDGE_AGENT_BRIDGE_MARKER="${BRIDGE_LAYOUT_MARKER_DIR:-$_BRIDGE_AGENT_BRIDGE_HOME/state}/layout-marker.sh"
    if [[ ! -f "$_BRIDGE_AGENT_BRIDGE_MARKER" ]] \
        && [[ -z "${BRIDGE_LAYOUT_RESOLVER_BYPASS:-}" ]]; then
      _BRIDGE_AGENT_BRIDGE_BYPASS_NONCE="$(date -u '+%Y%m%dT%H%M%SZ')-$$-${RANDOM}${RANDOM}"
      export BRIDGE_LAYOUT_RESOLVER_BYPASS="upgrade-migrate:${_BRIDGE_AGENT_BRIDGE_BYPASS_NONCE}"
      export BRIDGE_LAYOUT_RESOLVER_BYPASS_OWNER_PID=$$
      trap 'unset BRIDGE_LAYOUT_RESOLVER_BYPASS BRIDGE_LAYOUT_RESOLVER_BYPASS_OWNER_PID' EXIT
    fi
    unset _BRIDGE_AGENT_BRIDGE_HOME _BRIDGE_AGENT_BRIDGE_MARKER
    ;;
esac
# r15 codex Probe 6 (FAIL #7) — `isolation verify --help` must work
# even on legacy/markerless installs so operator can read the syntax
# before they upgrade. The layout-required guard inside bridge-lib.sh
# fires on legacy hosts and dies before the dispatcher would parse
# `--help`. Pre-empt by handling the help flag here, before sourcing
# bridge-lib.sh. Only the help case bypasses; an actual `verify`
# invocation still goes through the full layout check below.
if [[ "${1:-}" == "isolation" && "${2:-}" == "verify" ]]; then
  for _arg in "$@"; do
    if [[ "$_arg" == "-h" || "$_arg" == "--help" ]]; then
      cat <<'HELP_EOF'
Usage: agent-bridge isolation verify --agent <agent> [--json] [--strict-optional]

Walk the v0.9.7 grant matrix for <agent> and report mismatches.
Read-only — no chmod/chgrp/setfacl/mkdir. Exit non-zero on required mismatch.

Options:
  --agent <name>       Agent id (required).
  --json               Emit machine-readable output instead of the table.
  --strict-optional    Treat optional plugin rows as required (CLI exit
                       non-zero on any optional row reporting 'degraded').

Available even on legacy/markerless installs to advise upgrade.
Run `agent-bridge upgrade --apply` first to populate the v2 layout.
HELP_EOF
      exit 0
    fi
  done
  unset _arg
fi
# Issue #848 (codex r1 Vector 3): handle --help / -h / --version / -V
# BEFORE sourcing bridge-lib.sh. The previous short-circuit at the
# bottom of this file skipped bridge_load_roster but still paid the
# cost of `source bridge-lib.sh`, which transitively sources every
# `lib/bridge-*.sh` module — ~25 sources for ~50-80ms of cold-start
# residual on macOS. With the template-backed renderer below, neither
# the `--help` nor the `--version` short-circuit needs anything from
# bridge-lib.sh, so we exit before paying the source cost.
#
# The positional `version` subcommand continues to flow through the
# downstream handler (sourced bridge-lib, full --json / source-ref /
# upgrade-state formatting) since callers typing `agb version` are
# asking for the full version snapshot; only the `--version` / `-V`
# flag spellings get the fast print here.
#
# `usage()` downstream also reads from the same template via
# `bridge_print_usage_from_template`, so the slow (invalid-arg)
# fallback path stays in sync with this fast path automatically.
CLI_NAME="$(basename "$0")"

# Print the usage template with `__CLI_NAME__` substituted for the
# resolved CLI invocation name. Pure shell + sed — no bridge-lib
# dependency. Used by both the top-level --help short-circuit and
# the downstream usage() function so both paths stay byte-identical.
bridge_print_usage_from_template() {
  local template="$SCRIPT_DIR/scripts/cli-help/agent-bridge-usage.txt"
  if [[ ! -f "$template" ]]; then
    # Defensive fallback: template missing from a partial install.
    # Print a minimal hand-rolled hint so --help still exits 0 with
    # something actionable rather than dying silently.
    printf 'Usage: %s <subcommand> [options...]\n' "$CLI_NAME"
    printf '       %s --help     show full subcommand list\n' "$CLI_NAME"
    printf '       %s --version  show installed version\n' "$CLI_NAME"
    printf '(usage template missing: %s)\n' "$template" >&2
    return 0
  fi
  # Use a sed delimiter that cannot appear in CLI_NAME (`/`, `_`, `:`).
  # CLI_NAME is the result of `basename "$0"` so it is a filename
  # component without slashes — `|` is safe.
  sed "s|__CLI_NAME__|$CLI_NAME|g" "$template"
}

case "${1:-}" in
  --help|-h)
    bridge_print_usage_from_template
    exit 0
    ;;
  --version|-V)
    # Read VERSION directly — no bridge-lib (bridge_version lives in
    # lib/bridge-core.sh which we are explicitly avoiding sourcing on
    # this hot path).
    if [[ -f "$SCRIPT_DIR/VERSION" ]]; then
      printf 'Agent Bridge %s\n' "$(head -n 1 "$SCRIPT_DIR/VERSION" | tr -d '[:space:]')"
    else
      printf 'Agent Bridge 0.0.0-dev\n'
    fi
    exit 0
    ;;
esac

# shellcheck source=/dev/null
source "$SCRIPT_DIR/bridge-lib.sh"

# Skip roster load for commands that must remain mutation-free or own their
# own load timing. `init` defers bridge_load_roster until after argument
# parsing + the layout resolver decision (PR-F): calling it here would
# materialize $BRIDGE_HOME/state via bridge_init_dirs before --dry-run is
# even checked, breaking the dry-run mutation-free invariant.
#
# Issue #815 Wave A: also skip the top-level pre-dispatch load for the
# hot-path subcommands that own their own roster load timing
# (`status`, `daemon`, `agent`, `task`, `inbox`). On a stale runtime
# the eager top-level load runs `bridge_render_active_roster` (which
# fanned out into multi-record `done <<<` loops, the second-class
# heredoc_write hang vector). The subcommand dispatch paths still load
# the roster lazily when they actually need it; skipping here keeps
# `agb status` / `agb agent list` / `agb inbox <agent>` / `agb daemon
# start` startup well under 5s on the operator's live host.
#
# Issue #848: `--help` / `-h` / `--version` / `-V` are now handled at
# the TOP of this file (before `source bridge-lib.sh` above) — those
# tokens exit before they ever reach this case statement. The flag
# spellings are kept in the skip-list below as a belt-and-suspenders
# guard so that any future move of the top short-circuit cannot
# accidentally re-introduce the full roster-hydration cost (~0.8-1.1s
# of python3 cold-starts on macOS) on the help path. The `help`
# subcommand token is also kept so that an `agb help` style invocation
# (if a future patch adds the subcommand handler) does not eat the
# roster cost either.
case "${1:-}" in
  version|status|daemon|agent|task|inbox|help|--help|-h|--version|-V) ;;
  init)
    # bridge-isolation-v2.sh's `BRIDGE_LAYOUT="${BRIDGE_LAYOUT:-legacy}"`
    # default fires during our bridge-lib.sh source above and exports the
    # value into the environment we hand to the child bridge-init.sh.
    # When that default came from the resolver returning fresh-install-
    # candidate (BRIDGE_LAYOUT_SOURCE=fresh-install-candidate or
    # missing-marker(existing) etc.), the child would misread it as an
    # explicit operator override and skip the marker-write branch.
    # Strip it so the child's resolver runs in a clean state. An
    # operator-provided override (BRIDGE_LAYOUT_SOURCE=env) is preserved.
    if [[ "${BRIDGE_LAYOUT_SOURCE:-}" != "env" ]]; then
      unset BRIDGE_LAYOUT BRIDGE_DATA_ROOT
    fi
    ;;
  *)
    bridge_load_roster
    ;;
esac

usage() {
  # Issue #848 (codex r1 Vector 3): delegate to the shared template
  # renderer defined near the top of this file. Keeps the slow-path
  # invalid-arg fallback (which lands here after bridge-lib has been
  # sourced) byte-identical to the fast-path `--help` short-circuit.
  bridge_print_usage_from_template
}


# Issue #848 r2 (codex Vector 3): `--help` / `-h` / `--version` / `-V`
# are handled at the TOP of this file before `source bridge-lib.sh`.
# No dispatch needed here anymore — those flags exit before this point.
# The positional `version` subcommand still flows through the dispatch
# table below (sourced bridge-lib path) to keep the full `--json` /
# `source-ref` / upgrade-state output for callers typing `agb version`.

is_tty() {
  [[ -t 0 && -t 1 ]]
}

prompt_spawn_mode() {
  local can_create_worktree="$1"
  local project_root="$2"
  shift 2
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate
  local state=""

  echo "[info] 현재 프로젝트에 정적 ${ENGINE} 역할이 있습니다: $project_root" >&2
  for candidate in "${candidates[@]}"; do
    if bridge_agent_is_active "$candidate"; then
      state="active (연결됨)"
    else
      state="stopped"
    fi
    printf '  %d. %s | session=%s | %s | workdir=%s\n' \
      "$index" \
      "$candidate" \
      "$(bridge_agent_session "$candidate")" \
      "$state" \
      "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done
  echo >&2
  echo "1) 기존 정적 역할 연결/깨우기 (권장)" >&2
  if [[ "$can_create_worktree" == "1" ]]; then
    echo "2) 새 isolated worktree worker 만들기 (고급)" >&2
    echo "3) 현재 checkout에서 새 dynamic worker 만들기" >&2
  else
    echo "2) 현재 checkout에서 새 dynamic worker 만들기" >&2
  fi

  while true; do
    printf '선택: ' >&2
    read -r choice
    case "$choice" in
      1)
        printf 'wake'
        return 0
        ;;
      2)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'new'
        else
          printf 'shared'
        fi
        return 0
        ;;
      3)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'shared'
          return 0
        fi
        ;;
    esac
    echo "올바른 번호를 입력하세요." >&2
  done
}

prompt_static_candidate() {
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate
  local state=""

  if [[ ${#candidates[@]} -eq 1 ]]; then
    printf '%s' "${candidates[0]}"
    return 0
  fi

  echo "[info] 연결/깨울 정적 역할을 선택하세요." >&2
  for candidate in "${candidates[@]}"; do
    if bridge_agent_is_active "$candidate"; then
      state="active (연결됨)"
    else
      state="stopped"
    fi
    printf '  %d. %s | session=%s | %s | workdir=%s\n' \
      "$index" \
      "$candidate" \
      "$(bridge_agent_session "$candidate")" \
      "$state" \
      "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done

  while true; do
    printf '역할 번호: ' >&2
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidates[@]} )); then
      printf '%s' "${candidates[$((choice - 1))]}"
      return 0
    fi
    echo "올바른 번호를 입력하세요." >&2
  done
}

start_static_agent() {
  local agent="$1"
  local start_args=()

  "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

  if [[ $REPLACE_MODE -eq 1 ]]; then
    start_args+=(--replace)
  fi
  if [[ $CONTINUE_EXPLICIT -eq 1 ]]; then
    if [[ $CONTINUE_MODE -eq 1 ]]; then
      start_args+=(--continue)
    else
      start_args+=(--no-continue)
    fi
  fi
  if [[ $ATTACH_MODE -eq 1 ]]; then
    start_args+=(--attach)
  fi
  if [[ $INSTALL_PROJECT_SKILL -eq 0 ]]; then
    start_args+=(--skip-project-skill)
  fi

  exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$agent" "${start_args[@]}"
}

# Issue #283 Track D: bare invocation prints help instead of falling through
# to the legacy ad-hoc spawn parser, which dies with the misleading
# "--codex 또는 --claude 중 하나를 지정하세요" error. The legacy spawn path is
# rare; the common path is queue/inbox dispatching, which is what the help
# summary highlights.
if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 ]]; then
  case "$1" in
    admin)
      shift
      ADMIN_AGENT="$(bridge_require_admin_agent)"
      ADMIN_ENGINE="$(bridge_agent_engine "$ADMIN_AGENT")"
      ADMIN_WORKDIR="$(bridge_agent_workdir "$ADMIN_AGENT")"
      ADMIN_SAFE_MODE=0
      ADMIN_REPLACE_MODE=0
      ADMIN_ATTACH_MODE=1
      ADMIN_FAST_REUSE_ELIGIBLE=1
      ADMIN_SESSION=""
      ADMIN_ARGS=()

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --safe-mode)
            ADMIN_SAFE_MODE=1
            shift
            ;;
          --replace)
            ADMIN_REPLACE_MODE=1
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --no-attach)
            ADMIN_ATTACH_MODE=0
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --continue|--no-continue|--no-project-skill)
            ADMIN_ARGS+=("$1")
            shift
            ;;
          --name|--workdir|--codex|--claude|--antigravity|--agy)
            bridge_die "'$CLI_NAME admin'은(는) 관리자 역할의 engine/workdir/name을 고정 사용합니다."
            ;;
          *)
            ADMIN_FAST_REUSE_ELIGIBLE=0
            ADMIN_ARGS+=("$@")
            break
            ;;
        esac
      done
      if ((${#ADMIN_ARGS[@]} > 0)); then
        set -- "${ADMIN_ARGS[@]}"
      else
        set --
      fi

      if [[ $ADMIN_SAFE_MODE -eq 1 ]]; then
        exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-agent.sh" safe-mode "$ADMIN_AGENT" "$@"
      fi

      # Common path: `agb admin` is often just "return to the running admin".
      # Avoid the recursive static-start path, daemon ensure, and another full
      # roster load when the admin tmux session already exists.
      ADMIN_SESSION="$(bridge_agent_session "$ADMIN_AGENT")"
      if [[ $ADMIN_FAST_REUSE_ELIGIBLE -eq 1 && $ADMIN_REPLACE_MODE -eq 0 \
          && -n "$ADMIN_SESSION" ]] \
          && bridge_tmux_session_exists "$ADMIN_SESSION"; then
        echo "[info] 세션 '$ADMIN_SESSION'이 이미 실행 중입니다."
        if [[ $ADMIN_ATTACH_MODE -eq 1 ]]; then
          bridge_attach_tmux_session "$ADMIN_SESSION"
        fi
        exit 0
      fi

      # Issue #715-C / #714-5: bridge-start.sh now exits non-zero when a
      # spawned tmux session dies inside the post-launch verify window.
      # Propagate that signal here (instead of `exec`-ing) so we can append
      # an admin-targeted remediation hint after the child's own log tail.
      # NOTE: `set -e` at the top of this script would terminate before
      # `_admin_rc=$?` runs on a nonzero child; the `|| _admin_rc=$?`
      # tail keeps the heredoc + exit-propagation reachable.
      _admin_rc=0
      "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/agent-bridge" "--$ADMIN_ENGINE" --name "$ADMIN_AGENT" --workdir "$ADMIN_WORKDIR" --loop "$@" \
        || _admin_rc=$?
      if [[ $_admin_rc -ne 0 ]]; then
        cat >&2 <<EOF
[오류] '$ADMIN_AGENT' 어드민 세션이 시작 직후 종료되었습니다.
진단:
  bash bridge-daemon.sh status
  grep "plugin MCP liveness miss\\|$ADMIN_AGENT died" "\$BRIDGE_HOME/state/daemon.log" | tail
  tail -20 "\$BRIDGE_HOME/agents/$ADMIN_AGENT/logs/\$(date +%Y%m%d).log"
설정 누락 가능성:
  agb setup discord    # discord relay token 등록
  agb setup teams      # microsoft teams access.json 등록
EOF
      fi
      exit "$_admin_rc"
      ;;
    bootstrap)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-bootstrap.sh" "$@"
      ;;
    init)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-init.sh" "$@"
      ;;
    version)
      shift
      VERSION_JSON=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --json)
            VERSION_JSON=1
            shift
            ;;
          -h|--help)
            echo "Usage: $CLI_NAME version [--json]"
            exit 0
            ;;
          *)
            bridge_die "지원하지 않는 version 옵션입니다: $1"
            ;;
        esac
      done

      CURRENT_VERSION="$(bridge_version)"
      SOURCE_HEAD="$(git -C "$SCRIPT_DIR" rev-parse HEAD 2>/dev/null || printf '')"
      SOURCE_SHORT="$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || printf '-')"
      SOURCE_REF="$(bridge_source_ref)"
      UPGRADE_STATE_FILE="$BRIDGE_HOME/state/upgrade/last-upgrade.json"

      if [[ $VERSION_JSON -eq 1 ]]; then
        bridge_require_python
        python3 - "$CURRENT_VERSION" "$SCRIPT_DIR" "$SOURCE_REF" "$SOURCE_HEAD" "$UPGRADE_STATE_FILE" <<'PY'
import json
import sys
from pathlib import Path

version, source_root, source_ref, source_head, state_file = sys.argv[1:]
state_path = Path(state_file)
try:
    state = json.loads(state_path.read_text(encoding="utf-8"))
except (FileNotFoundError, json.JSONDecodeError):
    state = {}

state_summary = {
    key: state.get(key, "")
    for key in ("version", "source_ref", "source_head", "source_root", "channel", "updated_at")
    if key in state
}
payload = {
    "version": version,
    "source_root": source_root,
    "source_ref": source_ref,
    "source_head": source_head,
    "installed": state_summary,
}
print(json.dumps(payload, ensure_ascii=False, indent=2))
PY
        exit 0
      fi

      echo "Agent Bridge $CURRENT_VERSION"
      echo "source_root: $SCRIPT_DIR"
      echo "source_ref: $SOURCE_REF"
      echo "source_head: $SOURCE_SHORT"
      if [[ -f "$UPGRADE_STATE_FILE" ]]; then
        bridge_require_python
        python3 - "$UPGRADE_STATE_FILE" <<'PY'
import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except (FileNotFoundError, json.JSONDecodeError):
    raise SystemExit(0)

if payload.get("version"):
    print(f"installed_version: {payload.get('version')}")
if payload.get("source_ref"):
    print(f"installed_ref: {payload.get('source_ref')}")
if payload.get("source_head"):
    print(f"installed_head: {str(payload.get('source_head'))[:12]}")
PY
      fi
      exit 0
      ;;
    upgrade)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-upgrade.sh" "$@"
      ;;
    daemon)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" "$@"
      ;;
    auth)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-auth.sh" "$@"
      ;;
    escalate)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-escalate.sh" "$@"
      ;;
    upstream)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-upstream.sh" "$@"
      ;;
    review)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-review.sh" "$@"
      ;;
    user)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-user.sh" "$@"
      ;;
    guard)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-guard.sh" "$@"
      ;;
    diagnose)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-diagnose.sh" "$@"
      ;;
    doctor)
      shift
      bridge_require_python
      exec python3 "$SCRIPT_DIR/bridge-doctor.py" "$@"
      ;;
    knowledge)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-knowledge.sh" "$@"
      ;;
    skills)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-skills-cli.sh" "$@"
      ;;
    config)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-config.sh" "$@"
      ;;
    bundle)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-bundle.sh" "$@"
      ;;
    intake)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-intake.sh" "$@"
      ;;
    wave)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-wave.sh" "$@"
      ;;
    list)
      if [[ $# -ne 1 ]]; then
      bridge_die "Usage: $CLI_NAME list"
      fi
      bridge_list_active_agents_numbered
      exit 0
      ;;
    status)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-status.sh" "$@"
      ;;
    kill)
      if [[ $# -ne 2 ]]; then
        bridge_die "Usage: $CLI_NAME kill <number|name|all>"
      fi

      if [[ "$2" == "all" ]]; then
        bridge_kill_all_active_agents
      elif [[ "$2" =~ ^[0-9]+$ ]]; then
        bridge_kill_active_agent_by_index "$2"
      else
        if bridge_agent_is_active "$2"; then
          bridge_manual_stop_agent_session "$2"
          bridge_refresh_runtime_state
        else
          bridge_die "에이전트 '$2'가 활성 상태가 아닙니다."
        fi
      fi
      exit 0
      ;;
    attach)
      if [[ $# -gt 2 ]]; then
        bridge_die "Usage: $CLI_NAME attach [number|name]"
      fi
      if [[ $# -eq 1 ]]; then
        if ! is_tty; then
          bridge_die "Usage: $CLI_NAME attach <number|name>"
        fi
        echo "Active sessions:" >&2
        bridge_list_active_agents_numbered >&2
        printf 'Attach to: ' >&2
        read -r attach_choice
        [[ -n "$attach_choice" ]] || bridge_die "attach target is required"
        set -- "$1" "$attach_choice"
      fi
      if [[ "$2" =~ ^[0-9]+$ ]]; then
        agent="$(bridge_active_agent_id_by_index "$2")" || bridge_die "활성 에이전트 번호가 올바르지 않습니다: $2"
      else
        agent="$2"
      fi
      session="$(bridge_agent_session "$agent")"
      if [[ -z "$session" ]] || ! bridge_tmux_session_exists "$session"; then
        # Issue #714 (#7): operators previously had no on-screen remediation
        # path when an attach target was offline (e.g. after an upgrade where
        # orchestrate_restart silently failed). Surface the two recovery
        # commands that almost always close the loop before falling into
        # bridge_die's red error line.
        echo "[hint] 세션을 다시 시작하려면: bash bridge-start.sh $agent" >&2
        echo "[hint] (admin 에이전트인 경우) $CLI_NAME admin" >&2
        bridge_die "에이전트 '$agent'의 tmux 세션이 없습니다."
      fi
      bridge_attach_tmux_session "$session"
      ;;
    urgent)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-send.sh" --urgent "$@"
      ;;
    task)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
    profile)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-profile.sh" "$@"
      ;;
    setup)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-setup.sh" "$@"
      ;;
    agent)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-agent.sh" "$@"
      ;;
    cron)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-cron.sh" "$@"
      ;;
    memory)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-memory.sh" "$@"
      ;;
    audit)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-audit.sh" "$@"
      ;;
    usage)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-usage.sh" "$@"
      ;;
    watchdog)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-watchdog.sh" "$@"
      ;;
    discord)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-discord-relay.sh" "$@"
      ;;
    migrate)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-migrate.sh" "$@"
      ;;
    wiki)
      shift
      bridge_require_python
      exec python3 "$SCRIPT_DIR/bridge-wiki.py" "$@"
      ;;
    isolation)
      # v0.9.7 (refs #781): read-only verification CLI for the
      # isolation grant matrix. Walks every required-access matrix row
      # for an agent and reports per-row status. Does NOT mutate any
      # ownership/mode/ACL — operators run `migrate isolation v2
      # --apply --agent <X>` for repair.
      shift
      case "${1:-}" in
        verify)
          shift
          _iso_agent=""
          _iso_json=0
          _iso_strict_optional=0
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --agent)
                _iso_agent="$2"
                shift 2
                ;;
              --json)
                _iso_json=1
                shift
                ;;
              --strict-optional)
                # v0.9.7 PR 2 (refs #781): with this flag, `degraded`
                # rows (criticality=optional, mismatch) escalate to
                # `mismatch` and the CLI exits non-zero. Without it,
                # only required-row mismatches flip the exit code.
                _iso_strict_optional=1
                shift
                ;;
              -h|--help)
                cat <<EOF
Usage: $CLI_NAME isolation verify --agent <agent> [--json] [--strict-optional]

Read-only verification of the v2 isolation grant matrix for one agent.
Walks every required-access row and reports {path, expected, actual,
status, criticality, suggested_fix}. Exits non-zero on any required
mismatch.

  --agent <X>         agent id (required)
  --json              emit machine-readable JSON (default: human table)
  --strict-optional   treat optional row failures as required (CLI exit
                      non-zero on any optional 'degraded' row)

Suggested fix when verify reports drift:
  agent-bridge migrate isolation v2 --apply --agent <X>

This command never mutates filesystem state. Refs #781.
EOF
                exit 0
                ;;
              *)
                bridge_die "지원하지 않는 isolation verify 옵션입니다: $1"
                ;;
            esac
          done
          [[ -n "$_iso_agent" ]] || bridge_die "isolation verify: --agent <name> is required"

          # Source the v2 helpers — bridge-lib.sh already loaded the
          # module above, so the helpers are in scope. Run check.
          if ! command -v bridge_isolation_v2_apply_grant_matrix_for_agent >/dev/null 2>&1; then
            bridge_die "isolation verify: matrix helpers not loaded (BRIDGE_LAYOUT=v2 required)"
          fi

          _iso_check_out=""
          _iso_rc=0
          _iso_check_out="$(bridge_isolation_v2_apply_grant_matrix_for_agent "$_iso_agent" --check 2>&1)" \
            || _iso_rc=$?

          # v0.9.7 PR 2 (refs #781): apply_grant_matrix_for_agent now
          # demotes optional-row failures to status=`degraded` and does
          # NOT flip rc for them. With `--strict-optional`, the CLI
          # treats any `degraded` row as a hard mismatch for exit code
          # purposes (the row data itself stays `degraded` so the
          # operator can see which rows are optional vs required).
          if (( _iso_strict_optional == 1 )) \
              && [[ "$_iso_check_out" == *$'\tdegraded\t'* ]]; then
            _iso_rc=1
          fi

          if (( _iso_json == 1 )); then
            bridge_require_python
            # The check output is passed as a third positional arg so the
            # python heredoc remains the script source while data lands
            # in argv. This avoids the heredoc-overrides-pipe bash trap
            # (shellcheck SC2259) without writing temp files.
            python3 - "$_iso_agent" "$_iso_rc" "$_iso_check_out" "$_iso_strict_optional" <<'PY'
import json, sys
agent = sys.argv[1]
rc = int(sys.argv[2])
data = sys.argv[3] if len(sys.argv) > 3 else ""
strict_optional = sys.argv[4] == "1" if len(sys.argv) > 4 else False
rows = []
for line in data.splitlines():
    parts = line.split("\t")
    # 6-column format added in v0.9.7 PR 2: row, path, status,
    # expected, actual, criticality. Tolerate older 5-column lines so
    # consumers reading the upgrader's pre-upgrade snapshot don't break.
    if len(parts) < 5:
        continue
    row_name = parts[0]
    path = parts[1]
    status = parts[2]
    expected = parts[3]
    actual = parts[4]
    criticality = parts[5] if len(parts) > 5 else "required"
    rows.append({
        "row": row_name,
        "path": path,
        "status": status,
        "expected": expected,
        "actual": actual,
        "criticality": criticality,
        "suggested_fix": (
            f"agent-bridge migrate isolation v2 --apply --agent {agent}"
            if status != "ok" else ""
        ),
    })
print(json.dumps({
    "agent": agent,
    "exit_status": "ok" if rc == 0 else "mismatch",
    "strict_optional": strict_optional,
    "rows": rows,
}, ensure_ascii=False, indent=2))
PY
          else
            printf 'Isolation grant matrix verify for agent: %s\n' "$_iso_agent"
            if (( _iso_strict_optional == 1 )); then
              printf '%s\n' "(strict-optional: degraded rows escalated to required)"
            fi
            printf '%s\n' "------------------------------------------------------------------"
            printf '%-26s %-10s %-14s %-30s %s\n' "ROW" "STATUS" "CRITICALITY" "EXPECTED" "PATH"
            printf '%s\n' "------------------------------------------------------------------"
            while IFS=$'\t' read -r _name _path _status _expected _actual _crit; do
              [[ -n "$_name" ]] || continue
              # Tolerate 5-column input from older callers — fall back
              # to `required` so the table still renders sensibly.
              [[ -n "$_crit" ]] || _crit="required"
              printf '%-26s %-10s %-14s %-30s %s\n' \
                "$_name" "$_status" "$_crit" "$_expected" "$_path"
            done <<<"$_iso_check_out"
            printf '%s\n' "------------------------------------------------------------------"
            if (( _iso_rc == 0 )); then
              if [[ "$_iso_check_out" == *$'\tdegraded\t'* ]]; then
                echo "All required rows: ok (some optional rows degraded)"
                echo "Run with --strict-optional to fail on optional row degradation."
              else
                echo "All required rows: ok"
              fi
            else
              echo "Drift detected. Repair with:"
              echo "  agent-bridge migrate isolation v2 --apply --agent $_iso_agent"
            fi
          fi
          exit "$_iso_rc"
          ;;
        ""|-h|--help)
          cat <<EOF
Usage: $CLI_NAME isolation <verify> [options]

  verify --agent <X> [--json] [--strict-optional]
       Read-only verification of the v2 grant matrix for one agent.

Refs #781.
EOF
          exit 0
          ;;
        *)
          bridge_die "지원하지 않는 isolation 명령입니다: $1"
          ;;
      esac
      ;;
    isolate)
      shift
      bridge_migration_isolate_cli "$@"
      exit 0
      ;;
    unisolate)
      shift
      bridge_migration_unisolate_cli "$@"
      exit 0
      ;;
    worktree)
      shift
      case "${1:-}" in
        list|"")
          if [[ $# -gt 1 ]]; then
            bridge_die "Usage: $CLI_NAME worktree list"
          fi
          bridge_list_worktrees
          exit 0
          ;;
        doctor)
          shift
          bridge_worktree_doctor "$@"
          exit 0
          ;;
        *)
          bridge_die "지원하지 않는 worktree 명령입니다: $1"
          ;;
      esac
      ;;
    inbox|show|claim|done|cancel|update|handoff|summary|create)
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
  esac

  # Issue #163: if the first arg survived the top-level case and does not
  # start with `-` it is overwhelmingly a mistyped subcommand (e.g.
  # `agent-bridge health`, `agent-bridge diag`). Letting it fall through
  # into the spawn-flag parser surfaces the misleading "알 수 없는 옵션"
  # error, which previously redirected agents into option-guessing or the
  # sqlite3 fallback path. Reject with an intent-recovery suggestion
  # before the spawn parser sees it.
  if [[ -n "${1:-}" && "${1:0:1}" != "-" ]]; then
    _top_valid="admin bootstrap init version upgrade daemon auth escalate upstream review user guard diagnose doctor knowledge config bundle intake list status kill attach urgent task profile setup agent cron memory audit usage watchdog discord migrate wiki isolate unisolate worktree inbox show claim done cancel update handoff summary create"
    _hint="$(bridge_suggest_subcommand "$1" "$_top_valid")"
    [[ -n "$_hint" ]] && bridge_warn "$_hint"
    bridge_die "지원하지 않는 명령입니다: $1"
  fi
fi

ENGINE=""
NAME=""
WORKDIR="$(pwd)"
WORKDIR_EXPLICIT=0
LOOP_MODE=0
CONTINUE_MODE=1
CONTINUE_EXPLICIT=0
ATTACH_MODE=1
REPLACE_MODE=0
INSTALL_PROJECT_SKILL=1
SPAWN_PREFERENCE=""
# Issue #598 Track 4: opt-in for test-artifact name patterns.
TEST_FIXTURE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --codex)
      ENGINE="codex"
      shift
      ;;
    --claude)
      ENGINE="claude"
      shift
      ;;
    --antigravity|--agy)
      ENGINE="antigravity"
      shift
      ;;
    --name)
      [[ $# -lt 2 ]] && bridge_die "--name 뒤에 에이전트 이름을 지정하세요."
      NAME="$2"
      shift 2
      ;;
    --loop)
      LOOP_MODE=1
      shift
      ;;
    --no-continue)
      CONTINUE_MODE=0
      CONTINUE_EXPLICIT=1
      shift
      ;;
    --continue)
      CONTINUE_MODE=1
      CONTINUE_EXPLICIT=1
      shift
      ;;
    --workdir)
      [[ $# -lt 2 ]] && bridge_die "--workdir 뒤에 경로를 지정하세요."
      WORKDIR="$2"
      WORKDIR_EXPLICIT=1
      shift 2
      ;;
    --replace)
      REPLACE_MODE=1
      shift
      ;;
    --no-attach)
      ATTACH_MODE=0
      shift
      ;;
    --no-project-skill)
      INSTALL_PROJECT_SKILL=0
      shift
      ;;
    --prefer)
      [[ $# -lt 2 ]] && bridge_die "--prefer 뒤에 wake|new|shared 중 하나를 지정하세요."
      SPAWN_PREFERENCE="$2"
      shift 2
      ;;
    --test-fixture)
      # Issue #598 Track 4: opt into test-artifact-prefix policy.
      TEST_FIXTURE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      bridge_die "알 수 없는 옵션: $1"
      ;;
  esac
done

[[ -z "$ENGINE" ]] && bridge_die "--codex, --claude, --antigravity 중 하나를 지정하세요."
[[ -z "$NAME" ]] && bridge_die "--name은 필수입니다."

if ! bridge_validate_agent_name "$NAME"; then
  # Issue #526: same leading-dash / reserved-name rejection as `agent
  # create`. Helps users who accidentally typed `--name --help`.
  case "$NAME" in
    -*)
      bridge_die "이름이 CLI 플래그처럼 보입니다: '$NAME'. 도움말은 '$CLI_NAME --help' 를 실행하세요."
      ;;
    *)
      bridge_die "이름은 영문/숫자/점/밑줄/하이픈만 허용하고 영문/숫자로 시작해야 하며 'help'/'version' 은 예약어입니다: $NAME"
      ;;
  esac
fi

case "$SPAWN_PREFERENCE" in
  ""|wake|new|shared)
    ;;
  *)
    bridge_die "--prefer 는 wake|new|shared 중 하나여야 합니다."
    ;;
esac

WORKDIR="$(cd "$WORKDIR" && pwd -P)"

if ! bridge_agent_exists "$NAME"; then
  if RESOLVED_AGENT="$(bridge_agent_id_for_session "$NAME")"; then
    echo "[info] 세션 '$NAME'은(는) 역할 '$RESOLVED_AGENT'에 연결됩니다."
    NAME="$RESOLVED_AGENT"
  fi
fi

# Issue #598 Track 4: refuse names that match a test-artifact pattern
# (smoke-, test-, bootstrap-, created-agent-, pref-, *-repro-<N>) on
# truly-new dynamic spawns unless the operator opted in with
# --test-fixture. Existing static/dynamic agents are grandfathered:
# the check only fires when the name does not already resolve to a
# known agent. Cleanup tooling (Track 2 orphan-agent-dir detector)
# treats test-fixture agents as reapable.
if ! bridge_agent_exists "$NAME"; then
  if bridge_validate_agent_name_test_artifact "$NAME"; then
    if [[ $TEST_FIXTURE -eq 0 ]]; then
      bridge_die "agent-bridge --name '$NAME' refused: name matches test-artifact pattern.
Use \`--test-fixture\` if this is intentional test setup; cleanup tooling may
report and reap test-fixture agents per their pattern."
    else
      bridge_audit_log agent agent_test_fixture_created "$NAME" \
        --detail reason=test-fixture-flag \
        --detail entrypoint=spawn \
        2>/dev/null || true
    fi
  fi
fi

if bridge_agent_exists "$NAME" && [[ "$(bridge_agent_source "$NAME")" == "static" ]]; then
  STATIC_ENGINE="$(bridge_agent_engine "$NAME")"
  STATIC_WORKDIR="$(bridge_agent_workdir "$NAME")"
  if [[ -d "$STATIC_WORKDIR" ]]; then
    STATIC_WORKDIR="$(cd "$STATIC_WORKDIR" && pwd -P)"
  fi

  if [[ "$STATIC_ENGINE" != "$ENGINE" ]]; then
    bridge_die "'$NAME'은(는) ${STATIC_ENGINE} 정적 역할입니다. 요청 엔진(${ENGINE})과 다릅니다."
  fi
  if [[ $WORKDIR_EXPLICIT -eq 1 && "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    bridge_die "'$NAME' 정적 역할은 workdir이 고정되어 있습니다: $STATIC_WORKDIR"
  fi
  if [[ "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    echo "[info] '$NAME' 정적 역할의 고정 workdir을 사용합니다: $STATIC_WORKDIR"
    WORKDIR="$STATIC_WORKDIR"
  fi

  start_static_agent "$NAME"
fi

PROJECT_ROOT="$(bridge_project_root_for_path "$WORKDIR")"
IS_GIT_PROJECT=0
if git -C "$WORKDIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  IS_GIT_PROJECT=1
fi

mapfile -t STATIC_CANDIDATES < <(bridge_static_agents_for_project_engine "$PROJECT_ROOT" "$ENGINE")
if [[ ${#STATIC_CANDIDATES[@]} -gt 0 ]]; then
  if [[ -z "$SPAWN_PREFERENCE" ]] && is_tty; then
    SPAWN_PREFERENCE="$(prompt_spawn_mode "$IS_GIT_PROJECT" "$PROJECT_ROOT" "${STATIC_CANDIDATES[@]}")"
    echo
  elif [[ -z "$SPAWN_PREFERENCE" ]]; then
    # Task #4813: never silently hijack an explicit `--name <X>` in
    # non-TTY mode. Prior to this guard, a single-static-candidate
    # project would default to `wake` and redirect the operator's
    # named dynamic spawn (e.g. `--name shopicode`) to the existing
    # static role (e.g. `patch`), dropping the explicit name on the
    # floor. The matching-static path was already handled at line
    # ~1084 above (`bridge_agent_exists && static` → start_static_agent),
    # so by the time we reach here NAME is definitively NOT one of
    # these static roles — the operator's named-dynamic intent is
    # unambiguous. Default to `shared` (current checkout, new dynamic
    # worker alongside the static role). Operator can still pass
    # `--prefer wake` or `--prefer new` to override.
    SPAWN_PREFERENCE="shared"
  fi

  case "$SPAWN_PREFERENCE" in
    wake)
      if is_tty; then
        WAKE_AGENT="$(prompt_static_candidate "${STATIC_CANDIDATES[@]}")"
      elif [[ ${#STATIC_CANDIDATES[@]} -eq 1 ]]; then
        WAKE_AGENT="${STATIC_CANDIDATES[0]}"
      else
        bridge_die "깨울 정적 역할이 여러 개입니다. TTY에서 선택하거나 --name 으로 정적 역할을 직접 지정하세요."
      fi
      echo "[info] 새 dynamic worker '$NAME' 대신 정적 역할 '$WAKE_AGENT'를 깨웁니다."
      start_static_agent "$WAKE_AGENT"
      ;;
    new)
      if [[ "$IS_GIT_PROJECT" != "1" ]]; then
        bridge_die "현재 경로는 git 프로젝트가 아니어서 isolated worktree를 만들 수 없습니다: $WORKDIR"
      fi
      WORKDIR="$(bridge_prepare_isolated_worktree "$ENGINE" "$NAME" "$WORKDIR")"
      REPLACE_MODE=1
      echo "[info] isolated worktree를 사용합니다: $WORKDIR"
      ;;
    shared)
      :
      ;;
  esac
fi

ACTIVE_FILE="$(bridge_dynamic_agent_file_for "$NAME")"
HISTORY_FILE="$(bridge_history_file_for "$ENGINE" "$NAME" "$WORKDIR")"
SESSION_ID=""

if [[ -f "$ACTIVE_FILE" ]]; then
  bridge_load_roster
  if bridge_agent_is_active "$NAME" && [[ $REPLACE_MODE -eq 0 ]]; then
    EXISTING_ENGINE="$(bridge_agent_engine "$NAME")"
    EXISTING_WORKDIR="$(bridge_agent_workdir "$NAME")"
    EXISTING_LOOP="$(bridge_agent_loop "$NAME")"
    EXISTING_CONTINUE="$(bridge_agent_continue "$NAME")"

    if [[ "$EXISTING_ENGINE" != "$ENGINE" || "$EXISTING_WORKDIR" != "$WORKDIR" || "$EXISTING_LOOP" != "$LOOP_MODE" || "$EXISTING_CONTINUE" != "$CONTINUE_MODE" ]]; then
      bridge_die "'$NAME' 세션이 이미 실행 중이지만 요청한 설정과 다릅니다. existing: engine=$EXISTING_ENGINE workdir=$EXISTING_WORKDIR loop=$EXISTING_LOOP continue=$EXISTING_CONTINUE | requested: engine=$ENGINE workdir=$WORKDIR loop=$LOOP_MODE continue=$CONTINUE_MODE | '$CLI_NAME kill <number>' 또는 '--replace'를 사용하세요."
    fi

    echo "[info] '$NAME' 세션이 이미 실행 중입니다. 기존 세션에 연결합니다."
    if [[ $ATTACH_MODE -eq 1 ]]; then
      bridge_attach_tmux_session "$(bridge_agent_session "$NAME")"
    fi
    exit 0
  fi
fi

if [[ $CONTINUE_MODE -eq 1 && -f "$HISTORY_FILE" ]]; then
  AGENT_SESSION_ID=""
  # shellcheck source=/dev/null
  source "$HISTORY_FILE"
  # Gate the stored id through the freshness resolver. rc=0 keeps it,
  # rc=2 swaps in a fresher in-window transcript for the same workdir,
  # anything else means start fresh (no --resume). This is the dynamic
  # ad-hoc analogue of the hydration sites in lib/bridge-state.sh.
  _RESUME_RC=0
  SESSION_ID="$(bridge_resolve_resume_session_id "$ENGINE" "$NAME" "$WORKDIR" "${AGENT_SESSION_ID:-}" 2>/dev/null)" || _RESUME_RC=$?
  case "$_RESUME_RC" in
    0|2) ;;
    *)   SESSION_ID="" ;;
  esac
  unset _RESUME_RC
fi

bridge_add_agent_id_if_missing "$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_DESC["$NAME"]="Ad hoc ${ENGINE} agent (${WORKDIR})"
# shellcheck disable=SC2034
BRIDGE_AGENT_ENGINE["$NAME"]="$ENGINE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION["$NAME"]="$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_WORKDIR["$NAME"]="$WORKDIR"
# shellcheck disable=SC2034
BRIDGE_AGENT_SOURCE["$NAME"]="dynamic"
# shellcheck disable=SC2034
BRIDGE_AGENT_META_FILE["$NAME"]="$ACTIVE_FILE"
# shellcheck disable=SC2034
BRIDGE_AGENT_LOOP["$NAME"]="$LOOP_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_CONTINUE["$NAME"]="$CONTINUE_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION_ID["$NAME"]="$SESSION_ID"
# shellcheck disable=SC2034
BRIDGE_AGENT_HISTORY_KEY["$NAME"]="$(bridge_history_key_for "$ENGINE" "$NAME" "$WORKDIR")"
# shellcheck disable=SC2034
BRIDGE_AGENT_CREATED_AT["$NAME"]="$(date +%s)"
# shellcheck disable=SC2034
BRIDGE_AGENT_UPDATED_AT["$NAME"]="$(bridge_now_iso)"
bridge_write_dynamic_agent_file "$NAME" "$ACTIVE_FILE"

"$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

START_ARGS=()
if [[ $REPLACE_MODE -eq 1 ]]; then
  START_ARGS+=(--replace)
fi
if [[ $ATTACH_MODE -eq 1 ]]; then
  START_ARGS+=(--attach)
fi
if [[ $INSTALL_PROJECT_SKILL -eq 0 ]]; then
  START_ARGS+=(--skip-project-skill)
fi

exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$NAME" "${START_ARGS[@]}"
